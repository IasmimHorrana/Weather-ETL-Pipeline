# ==========================================
# OPENWEATHER API (Extração de Dados)
# ==========================================
# Obtenha sua chave gratuita em: https://openweathermap.org/api
API_KEY=sua_chave_aqui

# ==========================================
# POSTGRESQL (Banco de Dados)
# ==========================================
POSTGRES_USER=weather_user
POSTGRES_PASSWORD=weather_pass
POSTGRES_DB=weather_db
DATABASE_URL=postgresql://weather_user:weather_pass@localhost:5432/weather_db

# ==========================================
# MINIO (Object Storage — Camada Bronze)
# ==========================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# Quando rodar fora do Docker (ex: uv run python src/extract.py):
MINIO_ENDPOINT=http://localhost:9000
# Quando rodar dentro da rede Docker (Airflow, etc.):
# MINIO_ENDPOINT=http://minio:9000
MINIO_BRONZE_BUCKET=weather-bronze

# ==========================================
# ALERTAS via Telegram (Opcional)
# ==========================================
# Deixe em branco para usar apenas logs no terminal.
# Guia: https://core.telegram.org/bots#how-do-i-create-a-bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
